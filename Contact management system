#include <stdio.h>

struct Contact {
    char name[50];
    char phone[15];
    char email[50];
};

int main() {
    int n, i;

    printf("===== Contact Management System =====\n");
    printf("Enter number of contacts: ");
    scanf("%d", &n);

    struct Contact contacts[n];

    // Add contacts
    for(i = 0; i < n; i++) {
        printf("\nEnter details for Contact %d\n", i + 1);

        printf("Name: ");
        scanf(" %[^\n]", contacts[i].name);

        printf("Phone Number: ");
        scanf("%s", contacts[i].phone);

        printf("Email: ");
        scanf("%s", contacts[i].email);
    }

    // Display contacts
    printf("\n===== Contact List =====\n");
    printf("%-20s %-15s %-30s\n", "Name", "Phone", "Email");

    for(i = 0; i < n; i++) {
        printf("%-20s %-15s %-30s\n",
               contacts[i].name,
               contacts[i].phone,
               contacts[i].email);
    }

    return 0;
}
